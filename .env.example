# CS 5374 - API Configuration
# Copy this file to .env and fill in the keys you need.
# You only need the keys for the providers you're testing.

# === LangSmith Tracing (optional) ===
# Get your key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_key_here
LANGCHAIN_PROJECT=cs5374-blind-agent
# For local Ollama routing through LangSmith:
OPENAI_API_KEY=ollama

# === Google Gemini ($300 free Google Cloud credit) ===
# Get your key at: https://aistudio.google.com/apikeys
GOOGLE_API_KEY=AIza_your_key_here

# === Anthropic (required for adaptive red team attacker) ===
# Get your key at: https://console.anthropic.com/settings/keys
# Note: Requires prepaid credit (min $5). Sonnet runs cost ~$0.50/session.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === OpenAI (optional, for GPT targets) ===
# OPENAI_API_KEY=sk-your_key_here
